{
  "name": "@lannguyensi/grounding-wrapper",
  "version": "0.4.0",
  "description": "Plans grounding sessions for agents (recommended tool sequence, guardrails, phases). Pure planner; enforcement is external.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LanNguyenSi/agent-grounding.git",
    "directory": "packages/grounding-wrapper"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "default": "./dist/lib.js"
    },
    "./cli": "./dist/index.js"
  },
  "bin": {
    "grounding-wrapper": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x ./dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:ci": "jest --ci --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.0.0"
  }
}
