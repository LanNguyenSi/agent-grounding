{
  "name": "@lannguyensi/runtime-reality-checker",
  "version": "0.3.0",
  "description": "Checks if actual runtime state matches documentation and assumptions; ships a PreToolUse policy PoC",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LanNguyenSi/agent-grounding.git",
    "directory": "packages/runtime-reality-checker"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./policy": {
      "types": "./dist/policy/index.d.ts",
      "default": "./dist/policy/index.js"
    }
  },
  "bin": {
    "runtime-reality-policy-pre-tool-use": "./dist/policy/pre-tool-use.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/policy/pre-tool-use.js",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3",
    "vitest": "^4.1.4"
  }
}
