{
  "name": "@lannguyensi/grounding-mcp",
  "version": "0.5.0",
  "description": "MCP server exposing the agent-grounding stack (grounding-wrapper, evidence-ledger, claim-gate, hypothesis-tracker) to long-running Claude Code sessions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LanNguyenSi/agent-grounding.git",
    "directory": "packages/grounding-mcp"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "type": "module",
  "bin": {
    "grounding-mcp": "./dist/server.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/server.js",
    "dev": "tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@lannguyensi/claim-gate": "0.4.0",
    "@lannguyensi/evidence-ledger": "0.4.0",
    "@lannguyensi/grounding-wrapper": "0.4.0",
    "@lannguyensi/hypothesis-tracker": "0.4.0",
    "@lannguyensi/runtime-reality-checker": "0.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3",
    "vitest": "^4.1.4"
  }
}
