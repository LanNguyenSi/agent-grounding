{
  "name": "@lannguyensi/readme-first-resolver",
  "version": "0.1.0",
  "description": "Forces agents to read primary docs before any analysis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LanNguyenSi/agent-grounding.git",
    "directory": "packages/readme-first-resolver"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "main": "dist/index.js",
  "bin": {
    "readme-first": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x ./dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:ci": "jest --ci --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "glob": "^10.3.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.0.0"
  }
}
